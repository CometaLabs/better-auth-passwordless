{
  "name": "@cometalabs/better-auth-passwordless",
  "version": "0.1.0",
  "description": "Passwordless authentication plugin for Better Auth — OTP codes and magic links via email",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/server.ts src/client.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/server.ts src/client.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "better-auth",
    "passwordless",
    "otp",
    "magic-link",
    "authentication",
    "plugin"
  ],
  "author": "Cometalabs <alex@cometalabs.io>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "better-auth": "^1"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "better-auth": "^1"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
